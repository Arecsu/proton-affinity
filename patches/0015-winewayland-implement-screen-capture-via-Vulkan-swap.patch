+/* Minimal physdev: the wayland driver does not own a backing surface for GDI
+ * DCs, but a physdev entry is required so the driver appears in the DC stack
+ * and pGetImage reaches WAYLAND_GetImage for screen DCs. */
+struct wayland_physdev
+{
+    struct gdi_physdev dev;
+};
+
+/***********************************************************************
+ *           WAYLAND_CreateDC
+ */
+BOOL WAYLAND_CreateDC(PHYSDEV *pdev, LPCWSTR device, LPCWSTR output, const DEVMODEW *initData)
+{
+    struct wayland_physdev *physdev;
+
+    if (!(physdev = calloc(1, sizeof(*physdev)))) return FALSE;
+    push_dc_driver(pdev, &physdev->dev, &waylanddrv_funcs.dc_funcs);
+    return TRUE;
+}
+
+/***********************************************************************
+ *           WAYLAND_CreateCompatibleDC
+ */
+BOOL WAYLAND_CreateCompatibleDC(PHYSDEV orig, PHYSDEV *pdev)
+{
+    struct wayland_physdev *physdev;
+
+    if (!(physdev = calloc(1, sizeof(*physdev)))) return FALSE;
+    push_dc_driver(pdev, &physdev->dev, &waylanddrv_funcs.dc_funcs);
+    return TRUE;
+}
+
+/***********************************************************************
+ *           WAYLAND_DeleteDC
+ */
+BOOL WAYLAND_DeleteDC(PHYSDEV dev)
+{
+    free(dev);
+    return TRUE;
+}
+
+static void wayland_getimage_free(struct gdi_image_bits *bits)
+{
+    free(bits->param);
+}
+
+/***********************************************************************
+ *           WAYLAND_GetImage
+ *
+ * Returns the on-screen pixels covered by src->visrect by compositing the
+ * contents of all wayland-managed windows that intersect the rectangle.
+ * Vulkan-rendered windows are captured via win32u_vulkan_capture_window;
+ * GDI-backed windows are sampled from their cached shm contents.
+ *
+ * Called by GDI for BitBlt-from-screen and Graphics.CopyFromScreen, which
+ * is how applications such as Affinity Designer drive the color picker
+ * magnifier preview.
+ */
+DWORD WAYLAND_GetImage(PHYSDEV dev, BITMAPINFO *info, struct gdi_image_bits *bits,
+                       struct bitblt_coords *src)
+{
+    int width = src->visrect.right - src->visrect.left;
+    int height = src->visrect.bottom - src->visrect.top;
+    void *pixels;
+
+    info->bmiHeader.biSize          = sizeof(info->bmiHeader);
+    info->bmiHeader.biPlanes        = 1;
+    info->bmiHeader.biBitCount      = 32;
+    info->bmiHeader.biCompression   = BI_RGB;
+    info->bmiHeader.biXPelsPerMeter = 0;
+    info->bmiHeader.biYPelsPerMeter = 0;
+    info->bmiHeader.biClrUsed       = 0;
+    info->bmiHeader.biClrImportant  = 0;
+
+    if (!bits) return ERROR_SUCCESS; /* color-information query */
+
+    info->bmiHeader.biWidth     = width;
+    info->bmiHeader.biHeight    = -height; /* top-down */
+    info->bmiHeader.biSizeImage = width * height * 4;
+
+    if (!(pixels = calloc(1, width * height * 4))) return ERROR_OUTOFMEMORY;
+    wayland_composite_capture(pixels, width, height, src->visrect.left, src->visrect.top);
+
+    /* Force opaque alpha across the whole captured frame: GDI shm buffers
+     * carry whatever alpha the GDI layer wrote (often zero) and consumers
+     * that interpret BI_RGB 32bpp as ARGB would render zero-alpha pixels
+     * fully transparent. The captured Vulkan region is already opaque. */
+    {
+        uint32_t *p = pixels;
+        int i, n = width * height;
+        for (i = 0; i < n; i++) p[i] |= 0xFF000000u;
+    }
+
+    src->x -= src->visrect.left;
+    src->y -= src->visrect.top;
+    OffsetRect(&src->visrect, -src->visrect.left, -src->visrect.top);
+
+    bits->ptr = pixels;
+    bits->is_copy = TRUE;
+    bits->free = wayland_getimage_free;
+    bits->param = pixels;
+    return ERROR_SUCCESS;
+}
