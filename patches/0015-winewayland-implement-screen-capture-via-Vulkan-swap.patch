+    dp = dest + (dst_y * dest_w + dst_x) * 4;
+    sp = src + (src_y * src_w + src_x) * 4;
+    for (row = 0; row < copy_h; row++)
+    {
+        memcpy(dp, sp, copy_w * 4);
+        dp += dest_w * 4;
+        sp += src_w * 4;
