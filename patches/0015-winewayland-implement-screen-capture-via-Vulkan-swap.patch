+/* Per-window snapshot taken under win_data_mutex so the heavy pixel work below
+ * can run without holding the mutex. A window is captured as either a Vulkan
+ * client (vk == TRUE, capture happens later via win32u_vulkan_capture_window)
+ * or a GDI surface backed by shm (vk == FALSE). */
+struct capture_entry
+{
+    HWND hwnd;
+    RECT visible;
+    int depth;                       /* containment depth, used for paint order */
+    BOOL vk;
+    struct wayland_shm_buffer *shm; /* ref-held; NULL when vk == TRUE */
+};
