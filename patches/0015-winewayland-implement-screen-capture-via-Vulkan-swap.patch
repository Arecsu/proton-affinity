+static BOOL rect_contains(const RECT *outer, const RECT *inner)
+{
+    return outer->left <= inner->left && outer->top <= inner->top &&
+           outer->right >= inner->right && outer->bottom >= inner->bottom &&
+           !(outer->left == inner->left && outer->top == inner->top &&
+             outer->right == inner->right && outer->bottom == inner->bottom);
+}
+
+static int compare_capture_entries(const void *a, const void *b)
+{
+    return ((const struct capture_entry *)a)->depth - ((const struct capture_entry *)b)->depth;
+}
+
+/* Copy a w*h tile of BGRA8 pixels from src into dest at (dst_x, dst_y), where
+ * src has dimensions (src_w, src_h) and is sampled with the supplied scale.
+ * Both buffers are tightly packed (stride == width * 4). */
+static void blit_bgra(char *dest, int dest_w, int dest_h, int dst_x, int dst_y,
+                      const char *src, int src_w, int src_h, int src_x, int src_y,
+                      int copy_w, int copy_h)
+{
+    int row;
+    char *dp;
+    const char *sp;
+
+    if (dst_x < 0) { src_x -= dst_x; copy_w += dst_x; dst_x = 0; }
+    if (dst_y < 0) { src_y -= dst_y; copy_h += dst_y; dst_y = 0; }
+    if (src_x < 0 || src_y < 0) return;
+    if (src_x + copy_w > src_w) copy_w = src_w - src_x;
+    if (src_y + copy_h > src_h) copy_h = src_h - src_y;
+    if (dst_x + copy_w > dest_w) copy_w = dest_w - dst_x;
+    if (dst_y + copy_h > dest_h) copy_h = dest_h - dst_y;
+    if (copy_w <= 0 || copy_h <= 0) return;
