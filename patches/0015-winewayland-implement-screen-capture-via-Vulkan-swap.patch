From d77761d5576f4e84981f6f0a00eda6af054ac780 Mon Sep 17 00:00:00 2001
From: Arecsu <alejandro9r@gmail.com>
Date: Sun, 3 May 2026 23:24:19 -0300
Subject: [PATCH] winewayland: implement screen capture via Vulkan swapchain
 readback

Adds a synchronous on-demand path that captures the most-recently-presented
Vulkan swapchain image associated with a window into a host-visible BGRA8
buffer, exposed to display drivers via the new win32u_vulkan_capture_window
entry point. The wayland driver wires this into pGetImage so that
GDI / GDI+ screen captures (BitBlt-from-screen, Graphics.CopyFromScreen)
return real on-screen pixels for windows rendered by Vulkan-backed
clients such as DXVK.

win32u/vulkan.c:
- Promote the present mutex to file scope and add a hwnd-keyed surface
  registry so display drivers can locate a swapchain by window handle.
- Track the most-recently-presented image index, queue, and a per-swapchain
  present counter on every successful vkQueuePresentKHR.
- Lazily allocate per-swapchain capture resources (B8G8R8A8_UNORM blit
  image + host-visible mapped buffer + command pool / buffer / fence)
  sized to the current swapchain extent, reallocated on extent change.
- Force the swapchain's imageUsage to include TRANSFER_SRC so the host
  swapchain images can serve as the source of vkCmdBlitImage.
- Implement do_capture: blit last-presented image -> blit image -> copy
  to host-visible buffer on the same queue used for present, with
  bounded fence wait. The blit step uniformly handles any swapchain
  format and any extent, eliminating per-format CPU paths.
- Cache the captured pixels keyed by the swapchain's present counter:
  pollers (such as the color-picker magnifier) that sample faster than
  the application produces frames return the already-mapped buffer
  directly, with no GPU work and no second copy.
- Force opaque alpha on the captured pixels, since swapchain images
  carry undefined alpha but GDI+ consumers may interpret the result as
  ARGB and render zero-alpha pixels fully transparent.

winewayland.drv:
- New bitblt.c with the minimal DC plumbing (CreateDC / CreateCompatibleDC
  / DeleteDC) needed for the wayland driver to appear in the GDI DC stack,
  and pGetImage which builds the destination buffer and delegates the
  per-window painting to wayland_composite_capture.
- wayland_composite_capture in window.c: snapshots all wayland-managed
  windows under win_data_mutex, sorts entries by containment depth so
  parent windows paint first and children overlay them, then for each
  Vulkan-backed window pulls fresh pixels via win32u_vulkan_capture_window
  and for each shm-backed window copies from its existing buffer.
- Toplevel-reparenting fallback in WAYLAND_WindowPosChanged: if the
  natural toplevel ancestor of a window has no wayland role (typically
  a hidden helper window owned by middleware such as DXVK), pick the
  largest visible toplevel surface as the parent so popups (color-picker
  magnifier, tooltips) become visible.
- Wire the GDI dc_funcs into waylanddrv_funcs and expose the struct
  externally so bitblt.c can reference it from push_dc_driver.
---
 dlls/win32u/vulkan.c                   | 429 ++++++++++++++++++++++++-
 dlls/winewayland.drv/Makefile.in       |   1 +
 dlls/winewayland.drv/bitblt.c          | 140 ++++++++
 dlls/winewayland.drv/waylanddrv.h      |  12 +
 dlls/winewayland.drv/waylanddrv_main.c |   7 +-
 dlls/winewayland.drv/window.c          | 188 +++++++++++
 include/wine/vulkan_driver.h           |  10 +
 7 files changed, 782 insertions(+), 5 deletions(-)
 create mode 100644 dlls/winewayland.drv/bitblt.c

diff --git a/dlls/win32u/vulkan.c b/dlls/win32u/vulkan.c
index 826494706110..721dbecab61c 100644
--- a/dlls/win32u/vulkan.c
+++ b/dlls/win32u/vulkan.c
@@ -46,6 +46,18 @@ static PFN_vkEnumerateInstanceExtensionProperties p_vkEnumerateInstanceExtension
 static void *vulkan_handle;
 static struct vulkan_funcs vulkan_funcs;
 
+/* Serializes vkQueuePresentKHR and any external queue submissions performed
+ * on swapchain images (see win32u_vulkan_capture_window). */
+static pthread_mutex_t vulkan_present_lock = PTHREAD_MUTEX_INITIALIZER;
+
+/* Registry of HWND-bearing surfaces, used by win32u_vulkan_capture_window
+ * to locate the swapchain associated with a window. Protected by vulkan_present_lock. */
+static struct list surface_list = LIST_INIT(surface_list);
+
+struct swapchain;
+struct vulkan_device;
+static void destroy_capture_resources( struct vulkan_device *device, struct swapchain *swapchain );
+
 WINE_DECLARE_DEBUG_CHANNEL(fps);
 
 static const struct vulkan_driver_funcs *driver_funcs;
@@ -148,6 +160,7 @@ struct surface
     struct client_surface *client;
     struct swapchain *swapchain;
     HWND hwnd;
+    struct list entry; /* entry in surface_list */
 };
 
 static struct surface *surface_from_handle( VkSurfaceKHR handle )
@@ -232,6 +245,30 @@ struct swapchain
     struct fs_comp_pipeline blit_pipeline;
     struct fs_comp_pipeline fsr_easu_pipeline;
     struct fs_comp_pipeline fsr_rcas_pipeline;
+
+    /* Window capture support (see win32u_vulkan_capture_window). All access
+     * is serialized by vulkan_present_lock. */
+    struct vulkan_queue *last_present_queue;
+    uint32_t last_presented_image;
+    uint64_t present_count;       /* incremented on every successful present */
+    uint64_t captured_count;      /* present_count of the cached capture */
+    BOOL has_presented;
+
+    /* Lazily created on first capture. Sized to the swapchain extent at
+     * allocation time; reallocated if the extent grows. */
+    VkImage *capture_swapchain_images; /* host swapchain images, queried on first use */
+    uint32_t capture_swapchain_image_count;
+    VkImage capture_image;             /* B8G8R8A8_UNORM, blit destination */
+    VkDeviceMemory capture_image_memory;
+    VkExtent2D capture_extent;
+    VkBuffer capture_buffer;           /* host-visible mapped buffer, copy destination */
+    VkDeviceMemory capture_buffer_memory;
+    void *capture_pixels;
+    VkDeviceSize capture_buffer_size;
+    VkCommandPool capture_cmd_pool;
+    VkCommandBuffer capture_cmd;
+    VkFence capture_fence;
+    BOOL capture_in_flight;
 };
 
 static struct swapchain *swapchain_from_handle( VkSwapchainKHR handle )
@@ -1765,6 +1802,10 @@ static VkResult win32u_vkCreateWin32SurfaceKHR( VkInstance client_instance, cons
     surface->obj.instance = instance;
     instance->p_insert_object( instance, &surface->obj.obj );
 
+    pthread_mutex_lock( &vulkan_present_lock );
+    list_add_tail( &surface_list, &surface->entry );
+    pthread_mutex_unlock( &vulkan_present_lock );
+
     if (dummy) NtUserDestroyWindow( dummy );
 
     *ret = surface->obj.client.surface;
@@ -1782,6 +1823,10 @@ static void win32u_vkDestroySurfaceKHR( VkInstance client_instance, VkSurfaceKHR
     TRACE( "instance %p, handle 0x%s, allocator %p\n", instance, wine_dbgstr_longlong( client_surface ), allocator );
     if (allocator) FIXME( "Support for allocation callbacks not implemented yet\n" );
 
+    pthread_mutex_lock( &vulkan_present_lock );
+    list_remove( &surface->entry );
+    pthread_mutex_unlock( &vulkan_present_lock );
+
     instance->p_vkDestroySurfaceKHR( instance->host.instance, surface->obj.host.surface, NULL /* allocator */ );
     client_surface_release( surface->client );
 
@@ -2860,6 +2905,10 @@ static VkResult win32u_vkCreateSwapchainKHR( VkDevice client_device, const VkSwa
                    create_info_host.imageFormat );
     }
 
+    /* Window capture (win32u_vulkan_capture_window) reads from swapchain images
+     * via vkCmdBlitImage; ensure the host swapchain advertises this. */
+    create_info_host.imageUsage |= VK_IMAGE_USAGE_TRANSFER_SRC_BIT;
+
     if ((res = device->p_vkCreateSwapchainKHR( device->host.device, &create_info_host, NULL, &host_swapchain )))
     {
         free( swapchain );
@@ -2871,6 +2920,7 @@ static VkResult win32u_vkCreateSwapchainKHR( VkDevice client_device, const VkSwa
     client_surface_add_ref(surface->client);
     surface->swapchain = swapchain;
     swapchain->extents = create_info->imageExtent;
+    if (!swapchain->format) swapchain->format = create_info_host.imageFormat;
     instance->p_insert_object( instance, &swapchain->obj.obj );
 
     if (swapchain->fshack_dpi)
@@ -2933,6 +2983,10 @@ void win32u_vkDestroySwapchainKHR( VkDevice client_device, VkSwapchainKHR client
         free( swapchain->fs_hack_images );
     }
 
+    pthread_mutex_lock( &vulkan_present_lock );
+    destroy_capture_resources( device, swapchain );
+    pthread_mutex_unlock( &vulkan_present_lock );
+
     device->p_vkDestroySwapchainKHR( device->host.device, swapchain->obj.host.swapchain, NULL );
     if (swapchain->surface)
     {
@@ -3323,10 +3377,369 @@ static void *win32u_vk_find_struct_(void *s, VkStructureType t)
     return NULL;
 }
 
-static VkResult win32u_vkQueuePresentKHR( VkQueue client_queue, const VkPresentInfoKHR *client_present_info )
+/* Find the host memory type matching the requested property flag mask, preferring
+ * cached memory for HOST_VISIBLE host-readback buffers. */
+static uint32_t find_memory_type( struct vulkan_physical_device *physical_device,
+                                  uint32_t type_bits, VkMemoryPropertyFlags required,
+                                  VkMemoryPropertyFlags preferred )
+{
+    VkPhysicalDeviceMemoryProperties props;
+    uint32_t fallback = ~0u, i;
+
+    physical_device->instance->p_vkGetPhysicalDeviceMemoryProperties( physical_device->host.physical_device, &props );
+    for (i = 0; i < props.memoryTypeCount; i++)
+    {
+        VkMemoryPropertyFlags flags = props.memoryTypes[i].propertyFlags;
+        if (!(type_bits & (1u << i))) continue;
+        if ((flags & required) != required) continue;
+        if ((flags & preferred) == preferred) return i;
+        if (fallback == ~0u) fallback = i;
+    }
+    return fallback;
+}
+
+static void destroy_capture_resources( struct vulkan_device *device, struct swapchain *swapchain )
+{
+    if (swapchain->capture_fence)
+    {
+        if (swapchain->capture_in_flight)
+            device->p_vkWaitForFences( device->host.device, 1, &swapchain->capture_fence, VK_TRUE, ~0ull );
+        device->p_vkDestroyFence( device->host.device, swapchain->capture_fence, NULL );
+        swapchain->capture_fence = VK_NULL_HANDLE;
+        swapchain->capture_in_flight = FALSE;
+    }
+    if (swapchain->capture_cmd)
+    {
+        device->p_vkFreeCommandBuffers( device->host.device, swapchain->capture_cmd_pool, 1, &swapchain->capture_cmd );
+        swapchain->capture_cmd = VK_NULL_HANDLE;
+    }
+    if (swapchain->capture_cmd_pool)
+    {
+        device->p_vkDestroyCommandPool( device->host.device, swapchain->capture_cmd_pool, NULL );
+        swapchain->capture_cmd_pool = VK_NULL_HANDLE;
+    }
+    if (swapchain->capture_pixels)
+    {
+        device->p_vkUnmapMemory( device->host.device, swapchain->capture_buffer_memory );
+        swapchain->capture_pixels = NULL;
+    }
+    if (swapchain->capture_buffer)
+    {
+        device->p_vkDestroyBuffer( device->host.device, swapchain->capture_buffer, NULL );
+        swapchain->capture_buffer = VK_NULL_HANDLE;
+    }
+    if (swapchain->capture_buffer_memory)
+    {
+        device->p_vkFreeMemory( device->host.device, swapchain->capture_buffer_memory, NULL );
+        swapchain->capture_buffer_memory = VK_NULL_HANDLE;
+    }
+    if (swapchain->capture_image)
+    {
+        device->p_vkDestroyImage( device->host.device, swapchain->capture_image, NULL );
+        swapchain->capture_image = VK_NULL_HANDLE;
+    }
+    if (swapchain->capture_image_memory)
+    {
+        device->p_vkFreeMemory( device->host.device, swapchain->capture_image_memory, NULL );
+        swapchain->capture_image_memory = VK_NULL_HANDLE;
+    }
+    free( swapchain->capture_swapchain_images );
+    swapchain->capture_swapchain_images = NULL;
+    swapchain->capture_swapchain_image_count = 0;
+    swapchain->capture_buffer_size = 0;
+    swapchain->capture_extent.width = 0;
+    swapchain->capture_extent.height = 0;
+}
+
+/* Allocate (or reallocate) the capture blit image, host-visible buffer, command
+ * buffer and fence to match the current swapchain extent. */
+static VkResult init_capture_resources( struct vulkan_device *device, struct swapchain *swapchain,
+                                        uint32_t queue_family_index )
+{
+    VkExtent2D extent = swapchain->extents;
+    VkImageCreateInfo image_info = {.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO};
+    VkBufferCreateInfo buffer_info = {.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO};
+    VkMemoryAllocateInfo alloc_info = {.sType = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO};
+    VkMemoryRequirements mem_req;
+    VkDeviceSize buffer_size = (VkDeviceSize)extent.width * extent.height * 4;
+    uint32_t mem_type;
+    VkResult res;
+
+    if (swapchain->capture_extent.width == extent.width &&
+        swapchain->capture_extent.height == extent.height &&
+        swapchain->capture_image && swapchain->capture_buffer && swapchain->capture_cmd)
+        return VK_SUCCESS;
+
+    destroy_capture_resources( device, swapchain );
+
+    image_info.imageType = VK_IMAGE_TYPE_2D;
+    image_info.format = VK_FORMAT_B8G8R8A8_UNORM;
+    image_info.extent.width = extent.width;
+    image_info.extent.height = extent.height;
+    image_info.extent.depth = 1;
+    image_info.mipLevels = 1;
+    image_info.arrayLayers = 1;
+    image_info.samples = VK_SAMPLE_COUNT_1_BIT;
+    image_info.tiling = VK_IMAGE_TILING_OPTIMAL;
+    image_info.usage = VK_IMAGE_USAGE_TRANSFER_DST_BIT | VK_IMAGE_USAGE_TRANSFER_SRC_BIT;
+    image_info.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+    image_info.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+
+    if ((res = device->p_vkCreateImage( device->host.device, &image_info, NULL, &swapchain->capture_image )))
+    {
+        ERR( "vkCreateImage failed: %d\n", res );
+        return res;
+    }
+    device->p_vkGetImageMemoryRequirements( device->host.device, swapchain->capture_image, &mem_req );
+    mem_type = find_memory_type( device->physical_device, mem_req.memoryTypeBits,
+                                 VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT );
+    if (mem_type == ~0u) { res = VK_ERROR_OUT_OF_DEVICE_MEMORY; goto fail; }
+    alloc_info.allocationSize = mem_req.size;
+    alloc_info.memoryTypeIndex = mem_type;
+    if ((res = device->p_vkAllocateMemory( device->host.device, &alloc_info, NULL, &swapchain->capture_image_memory ))) goto fail;
+    device->p_vkBindImageMemory( device->host.device, swapchain->capture_image, swapchain->capture_image_memory, 0 );
+
+    buffer_info.size = buffer_size;
+    buffer_info.usage = VK_BUFFER_USAGE_TRANSFER_DST_BIT;
+    buffer_info.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+    if ((res = device->p_vkCreateBuffer( device->host.device, &buffer_info, NULL, &swapchain->capture_buffer ))) goto fail;
+    device->p_vkGetBufferMemoryRequirements( device->host.device, swapchain->capture_buffer, &mem_req );
+    mem_type = find_memory_type( device->physical_device, mem_req.memoryTypeBits,
+                                 VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT | VK_MEMORY_PROPERTY_HOST_COHERENT_BIT,
+                                 VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT | VK_MEMORY_PROPERTY_HOST_COHERENT_BIT |
+                                 VK_MEMORY_PROPERTY_HOST_CACHED_BIT );
+    if (mem_type == ~0u) { res = VK_ERROR_OUT_OF_HOST_MEMORY; goto fail; }
+    alloc_info.allocationSize = mem_req.size;
+    alloc_info.memoryTypeIndex = mem_type;
+    if ((res = device->p_vkAllocateMemory( device->host.device, &alloc_info, NULL, &swapchain->capture_buffer_memory ))) goto fail;
+    device->p_vkBindBufferMemory( device->host.device, swapchain->capture_buffer, swapchain->capture_buffer_memory, 0 );
+    if ((res = device->p_vkMapMemory( device->host.device, swapchain->capture_buffer_memory, 0, VK_WHOLE_SIZE, 0, &swapchain->capture_pixels ))) goto fail;
+
+    {
+        VkCommandPoolCreateInfo pool_info = {.sType = VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO};
+        VkCommandBufferAllocateInfo cmd_info = {.sType = VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO};
+        VkFenceCreateInfo fence_info = {.sType = VK_STRUCTURE_TYPE_FENCE_CREATE_INFO};
+
+        pool_info.flags = VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT;
+        pool_info.queueFamilyIndex = queue_family_index;
+        if ((res = device->p_vkCreateCommandPool( device->host.device, &pool_info, NULL, &swapchain->capture_cmd_pool ))) goto fail;
+        cmd_info.commandPool = swapchain->capture_cmd_pool;
+        cmd_info.level = VK_COMMAND_BUFFER_LEVEL_PRIMARY;
+        cmd_info.commandBufferCount = 1;
+        if ((res = device->p_vkAllocateCommandBuffers( device->host.device, &cmd_info, &swapchain->capture_cmd ))) goto fail;
+        if ((res = device->p_vkCreateFence( device->host.device, &fence_info, NULL, &swapchain->capture_fence ))) goto fail;
+    }
+
+    swapchain->capture_extent = extent;
+    swapchain->capture_buffer_size = buffer_size;
+    /* Invalidate the cached capture so the next call performs a fresh GPU
+     * copy at the new extent. */
+    swapchain->captured_count = 0;
+    if (swapchain->present_count == 0) swapchain->present_count = 1;
+    TRACE( "allocated capture resources for swapchain %p (%ux%u)\n", swapchain, extent.width, extent.height );
+    return VK_SUCCESS;
+
+fail:
+    ERR( "init_capture_resources failed: %d\n", res );
+    destroy_capture_resources( device, swapchain );
+    return res;
+}
+
+static VkResult do_capture( struct vulkan_device *device, struct swapchain *swapchain )
+{
+    VkImage src_image;
+    VkCommandBuffer cmd = swapchain->capture_cmd;
+    VkCommandBufferBeginInfo begin_info = {.sType = VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO,
+                                            .flags = VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT};
+    VkImageMemoryBarrier barriers[2] = {{0}};
+    VkImageBlit blit = {0};
+    VkBufferImageCopy copy = {0};
+    VkSubmitInfo submit_info = {.sType = VK_STRUCTURE_TYPE_SUBMIT_INFO};
+    VkResult res;
+
+    if (swapchain->fshack_dpi && swapchain->fs_hack_images)
+        src_image = swapchain->fs_hack_images[swapchain->last_presented_image].swapchain_image;
+    else if (swapchain->capture_swapchain_images && swapchain->last_presented_image < swapchain->capture_swapchain_image_count)
+        src_image = swapchain->capture_swapchain_images[swapchain->last_presented_image];
+    else
+        return VK_ERROR_INITIALIZATION_FAILED;
+
+    /* A previous capture's wait may have timed out, leaving the fence still
+     * pending. Reset is undefined while the GPU may still touch its associated
+     * resources, so wait it out with a generous bound before reuse. */
+    if (swapchain->capture_in_flight)
+    {
+        res = device->p_vkWaitForFences( device->host.device, 1, &swapchain->capture_fence, VK_TRUE, 1000 * 1000 * 1000ull );
+        if (res != VK_SUCCESS) return res;
+        swapchain->capture_in_flight = FALSE;
+    }
+    device->p_vkResetFences( device->host.device, 1, &swapchain->capture_fence );
+    device->p_vkResetCommandBuffer( cmd, 0 );
+    device->p_vkBeginCommandBuffer( cmd, &begin_info );
+
+    /* Source: PRESENT_SRC -> TRANSFER_SRC. Dest: UNDEFINED -> TRANSFER_DST. */
+    barriers[0].sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+    barriers[0].srcAccessMask = VK_ACCESS_MEMORY_READ_BIT;
+    barriers[0].dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+    barriers[0].oldLayout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR;
+    barriers[0].newLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+    barriers[0].srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+    barriers[0].dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+    barriers[0].image = src_image;
+    barriers[0].subresourceRange.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+    barriers[0].subresourceRange.levelCount = 1;
+    barriers[0].subresourceRange.layerCount = 1;
+
+    barriers[1] = barriers[0];
+    barriers[1].srcAccessMask = 0;
+    barriers[1].dstAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+    barriers[1].oldLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+    barriers[1].newLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+    barriers[1].image = swapchain->capture_image;
+
+    device->p_vkCmdPipelineBarrier( cmd, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT,
+                                    0, 0, NULL, 0, NULL, 2, barriers );
+
+    /* Blit src -> capture_image. Using vkCmdBlitImage handles both format
+     * conversion (any swapchain format -> BGRA8) and any extent mismatch. */
+    blit.srcSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+    blit.srcSubresource.layerCount = 1;
+    blit.srcOffsets[1].x = swapchain->capture_extent.width;
+    blit.srcOffsets[1].y = swapchain->capture_extent.height;
+    blit.srcOffsets[1].z = 1;
+    blit.dstSubresource = blit.srcSubresource;
+    blit.dstOffsets[1] = blit.srcOffsets[1];
+
+    device->p_vkCmdBlitImage( cmd, src_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
+                              swapchain->capture_image, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
+                              1, &blit, VK_FILTER_NEAREST );
+
+    /* capture_image: TRANSFER_DST -> TRANSFER_SRC for the readback copy. */
+    barriers[0].srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+    barriers[0].dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+    barriers[0].oldLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+    barriers[0].newLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+    barriers[0].image = swapchain->capture_image;
+    device->p_vkCmdPipelineBarrier( cmd, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT,
+                                    0, 0, NULL, 0, NULL, 1, barriers );
+
+    copy.imageSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+    copy.imageSubresource.layerCount = 1;
+    copy.imageExtent.width = swapchain->capture_extent.width;
+    copy.imageExtent.height = swapchain->capture_extent.height;
+    copy.imageExtent.depth = 1;
+    device->p_vkCmdCopyImageToBuffer( cmd, swapchain->capture_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
+                                      swapchain->capture_buffer, 1, &copy );
+
+    /* Restore source image to PRESENT_SRC so the application's next present
+     * sees the layout it expects. */
+    barriers[0].srcAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+    barriers[0].dstAccessMask = VK_ACCESS_MEMORY_READ_BIT;
+    barriers[0].oldLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+    barriers[0].newLayout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR;
+    barriers[0].image = src_image;
+    device->p_vkCmdPipelineBarrier( cmd, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT,
+                                    0, 0, NULL, 0, NULL, 1, barriers );
+
+    device->p_vkEndCommandBuffer( cmd );
+
+    submit_info.commandBufferCount = 1;
+    submit_info.pCommandBuffers = &cmd;
+    if ((res = device->p_vkQueueSubmit( swapchain->last_present_queue->host.queue, 1, &submit_info, swapchain->capture_fence )))
+    {
+        ERR( "vkQueueSubmit failed: %d\n", res );
