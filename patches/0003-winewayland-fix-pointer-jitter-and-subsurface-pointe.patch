From 94725a6560c055dc240852b8a8811c94111859f0 Mon Sep 17 00:00:00 2001
From: Arecsu <alejandro9r@gmail.com>
Date: Wed, 29 Apr 2026 21:43:52 -0300
Subject: [PATCH 03/14] winewayland: fix pointer jitter and subsurface pointer
 coordinate compensation

---
 dlls/winewayland.drv/wayland_pointer.c | 76 ++++++++++++++++++++++----
 1 file changed, 64 insertions(+), 12 deletions(-)

diff --git a/dlls/winewayland.drv/wayland_pointer.c b/dlls/winewayland.drv/wayland_pointer.c
index 82f2222309e..f78968a308d 100644
--- a/dlls/winewayland.drv/wayland_pointer.c
+++ b/dlls/winewayland.drv/wayland_pointer.c
@@ -141,6 +141,7 @@ static void pointer_handle_motion_internal(wl_fixed_t sx, wl_fixed_t sy)
     POINT screen;
     struct wayland_surface *surface;
     struct wayland_win_data *data;
+    int rect_left, rect_top, rect_right, rect_bottom;
 
     if (!(hwnd = wayland_pointer_get_focused_hwnd())) return;
     if (!(data = wayland_win_data_get(hwnd))) return;
@@ -152,18 +153,55 @@ static void pointer_handle_motion_internal(wl_fixed_t sx, wl_fixed_t sy)
 
     window_rect = &surface->window.rect;
 
+    /* For subsurfaces, compute screen position from the toplevel's rect
+     * plus the committed subsurface offset. The compositor sends pointer
+     * events in surface-local coords based on the COMMITTED subsurface
+     * position, which may lag behind our window.rect by one frame. Using
+     * window.rect directly causes a feedback loop during drag. */
+    if (surface->role == WAYLAND_SURFACE_ROLE_SUBSURFACE && surface->wl_subsurface)
+    {
+        struct wayland_win_data *toplevel_data = wayland_win_data_get_nolock(surface->toplevel_hwnd);
+        if (toplevel_data && toplevel_data->wayland_surface)
+        {
+            struct wayland_surface *toplevel_surface = toplevel_data->wayland_surface;
+            int offset_x, offset_y;
+            wayland_surface_coords_to_window(surface,
+                                             surface->subsurface_x,
+                                             surface->subsurface_y,
+                                             &offset_x, &offset_y);
+            rect_left = toplevel_surface->window.rect.left + offset_x;
+            rect_top = toplevel_surface->window.rect.top + offset_y;
+            rect_right = rect_left + (window_rect->right - window_rect->left);
+            rect_bottom = rect_top + (window_rect->bottom - window_rect->top);
+        }
+        else
+        {
+            rect_left = window_rect->left;
+            rect_top = window_rect->top;
+            rect_right = window_rect->right;
+            rect_bottom = window_rect->bottom;
+        }
+    }
+    else
+    {
+        rect_left = window_rect->left;
+        rect_top = window_rect->top;
+        rect_right = window_rect->right;
+        rect_bottom = window_rect->bottom;
+    }
+
     wayland_surface_coords_to_window(surface,
                                      wl_fixed_to_double(sx),
                                      wl_fixed_to_double(sy),
                                      (int *)&screen.x, (int *)&screen.y);
-    screen.x += window_rect->left;
-    screen.y += window_rect->top;
+    screen.x += rect_left;
+    screen.y += rect_top;
     /* Sometimes, due to rounding, we may end up with pointer coordinates
      * slightly outside the target window, so bring them within bounds. */
-    if (screen.x >= window_rect->right) screen.x = window_rect->right - 1;
-    else if (screen.x < window_rect->left) screen.x = window_rect->left;
-    if (screen.y >= window_rect->bottom) screen.y = window_rect->bottom - 1;
-    else if (screen.y < window_rect->top) screen.y = window_rect->top;
+    if (screen.x >= rect_right) screen.x = rect_right - 1;
+    else if (screen.x < rect_left) screen.x = rect_left;
+    if (screen.y >= rect_bottom) screen.y = rect_bottom - 1;
+    else if (screen.y < rect_top) screen.y = rect_top;
 
     wayland_win_data_release(data);
 
@@ -352,12 +390,26 @@ static void pointer_handle_frame(void *data, struct wl_pointer *wl_pointer)
 
     if (frame->flags & WAYLAND_POINTER_FRAME_RELATIVE)
     {
-        input.mi.dx = round(frame->dx);
-        input.mi.dy = round(frame->dy);
-        frame->dx -= input.mi.dx;
-        frame->dy -= input.mi.dy;
-        if (input.mi.dx != 0 || input.mi.dy != 0)
-            NtUserSendHardwareInput(hwnd, SEND_HWMSG_NO_RAW, &input, 0);
+        /* When absolute motion is also available, use it for cursor
+         * positioning (it's authoritative) and only forward the relative
+         * data as raw input. Sending both absolute and relative regular
+         * mouse moves causes the cursor to overshoot then snap back,
+         * producing visible jitter. */
+        if (!(frame->flags & WAYLAND_POINTER_FRAME_ABSOLUTE))
+        {
+            input.mi.dx = round(frame->dx);
+            input.mi.dy = round(frame->dy);
+            frame->dx -= input.mi.dx;
+            frame->dy -= input.mi.dy;
+            if (input.mi.dx != 0 || input.mi.dy != 0)
+                NtUserSendHardwareInput(hwnd, SEND_HWMSG_NO_RAW, &input, 0);
+        }
+        else
+        {
+            /* Discard accumulated relative delta since absolute took precedence */
+            frame->dx = 0;
+            frame->dy = 0;
+        }
 
         input.mi.dx = round(frame->dx_raw);
         input.mi.dy = round(frame->dy_raw);
