From 9339dd4cdeeff6fa3eb1870bfda91175bbc48055 Mon Sep 17 00:00:00 2001
From: Arecsu <alejandro9r@gmail.com>
Date: Sun, 3 May 2026 17:01:19 -0300
Subject: [PATCH] winewayland: mark layered attribs set when
 CreateWindowSurface re-runs with layered=TRUE

The normal creation path in WAYLAND_CreateWindowSurface marks
layered_attribs_set when called with layered=TRUE, gating window
visibility on properly-configured layered state. The early-return path
taken when the surface already exists did not perform the same update,
so a window transitioning to layered after surface creation could remain
invisible until SetLayeredWindowAttributes was explicitly called.
---
 dlls/winewayland.drv/window_surface.c | 14 +++++++++++++-
 1 file changed, 13 insertions(+), 1 deletion(-)

diff --git a/dlls/winewayland.drv/window_surface.c b/dlls/winewayland.drv/window_surface.c
index e7595b7ccb03..9a8e8a9f6ad3 100644
--- a/dlls/winewayland.drv/window_surface.c
+++ b/dlls/winewayland.drv/window_surface.c
@@ -519,7 +519,19 @@ BOOL WAYLAND_CreateWindowSurface(HWND hwnd, BOOL layered, const RECT *surface_re
 
     TRACE("hwnd %p, layered %u, surface_rect %s, surface %p\n", hwnd, layered, wine_dbgstr_rect(surface_rect), surface);
 
-    if ((previous = *surface) && previous->funcs == &wayland_window_surface_funcs) return TRUE;
+    if ((previous = *surface) && previous->funcs == &wayland_window_surface_funcs)
+    {
+        /* The early-return path skipped marking layered attribs as set, while
+         * the normal creation path below does so when called with layered=TRUE.
+         * Mirror that here so a window that gains layered status after its
+         * surface already exists still becomes eligible for display. */
+        if (layered && (data = wayland_win_data_get(hwnd)))
+        {
+            data->layered_attribs_set = TRUE;
+            wayland_win_data_release(data);
+        }
+        return TRUE;
+    }
     if (!(data = wayland_win_data_get(hwnd))) return TRUE; /* use default surface */
     if (previous) window_surface_release(previous);
 
